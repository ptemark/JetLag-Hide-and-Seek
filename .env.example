# JetLag: The Game — Environment Configuration Template
#
# Copy this file to .env.development, .env.staging, or .env.production
# and fill in the real values. Never commit files with real secrets.
#
# Vite exposes variables prefixed with VITE_ to the browser bundle.
# Variables without VITE_ are only available in serverless functions (Node.js).

# ---------------------------------------------------------------------------
# Environment name (development | staging | production)
# ---------------------------------------------------------------------------
VITE_ENV=development

# ---------------------------------------------------------------------------
# API — Serverless function base URL
# In development, Vite proxies to localhost; in prod, Vercel serves /api/*
# automatically — set this to your Vercel deployment URL.
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:3001

# ---------------------------------------------------------------------------
# WebSocket — Managed game-loop container URL
# Spins up on first player, shuts down when idle.
# ---------------------------------------------------------------------------
VITE_WS_URL=ws://localhost:3002

# ---------------------------------------------------------------------------
# Managed game server — URL of the on-demand WebSocket / game-loop container.
# Used by the /api/live and /api/admin serverless functions to proxy requests.
# Leave empty if running fully in-process (local dev / tests).
# ---------------------------------------------------------------------------
GAME_SERVER_URL=

# ---------------------------------------------------------------------------
# Database — Serverless Postgres (used by functions only, not the browser)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/jetlag

# ---------------------------------------------------------------------------
# Maps — OpenStreetMap is preferred ($0). Optionally supply a Google Maps
# API key to enable fallback tile layer or Distance Matrix queries.
# ---------------------------------------------------------------------------
VITE_MAPS_PROVIDER=osm
VITE_GOOGLE_MAPS_API_KEY=

# ---------------------------------------------------------------------------
# Admin API — Bearer token for the GET /admin endpoint (server-side only)
# Generate a strong random value, e.g.: openssl rand -hex 32
# Leave empty to disable the admin endpoint entirely.
# ---------------------------------------------------------------------------
ADMIN_API_KEY=

# ---------------------------------------------------------------------------
# Auto-scaling — Webhook URL and thresholds for scale-up/scale-down events.
# The managed game-loop server calls this URL when load crosses a threshold,
# allowing an orchestrator (ECS, Fly.io, Kubernetes, custom) to scale replicas.
# Leave SCALE_WEBHOOK_URL empty to disable webhook scaling notifications.
# ---------------------------------------------------------------------------
SCALE_WEBHOOK_URL=
# Active game count at or above which scale-up fires (default 5)
SCALE_UP_GAMES=5
# WebSocket connection count at or above which scale-up fires (default 20)
SCALE_UP_CONNECTIONS=20
# Active game count at or below which scale-down fires (default 0)
SCALE_DOWN_GAMES=0
# WebSocket connection count at or below which scale-down fires (default 0)
SCALE_DOWN_CONNECTIONS=0
# Minimum ms between consecutive events of the same direction (default 60 000 ms)
SCALE_COOLDOWN_MS=60000

# ---------------------------------------------------------------------------
# Alerting — Webhook URL for failure alert notifications (server-side only).
# POSTs a JSON payload on SERVER_CRASH, DB_ERROR, CONNECTION_DROP, etc.
# Compatible with Slack incoming webhooks, PagerDuty, or any HTTP endpoint.
# Leave empty to disable webhook alerting (logs still capture all alerts).
# ---------------------------------------------------------------------------
ALERT_WEBHOOK_URL=
# Error count threshold: fire ERROR_RATE_HIGH alert every N cumulative errors.
ALERT_ERROR_THRESHOLD=10

# ---------------------------------------------------------------------------
# Feature toggles (set to "true" / "false")
# ---------------------------------------------------------------------------
# Enable experimental two-team seeker mode
VITE_FEATURE_TWO_TEAMS=false
# Enable admin dashboard route
VITE_FEATURE_ADMIN_DASHBOARD=false
# Enable GPS real-time tracking overlay
VITE_FEATURE_GPS_TRACKING=true
