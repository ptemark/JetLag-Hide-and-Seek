# JetLag: The Game — Environment Configuration Template
#
# Copy this file to .env.development, .env.staging, or .env.production
# and fill in the real values. Never commit files with real secrets.
#
# Vite exposes variables prefixed with VITE_ to the browser bundle.
# Variables without VITE_ are only available in serverless functions (Node.js).

# ---------------------------------------------------------------------------
# Environment name (development | staging | production)
# ---------------------------------------------------------------------------
VITE_ENV=development

# ---------------------------------------------------------------------------
# API — Serverless function base URL
# In development, Vite proxies to localhost; in prod, set the deployed URL.
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:3001

# ---------------------------------------------------------------------------
# WebSocket — Managed game-loop container URL
# Spins up on first player, shuts down when idle.
# ---------------------------------------------------------------------------
VITE_WS_URL=ws://localhost:3002

# ---------------------------------------------------------------------------
# Database — Serverless Postgres (used by functions only, not the browser)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/jetlag

# ---------------------------------------------------------------------------
# Maps — OpenStreetMap is preferred ($0). Optionally supply a Google Maps
# API key to enable fallback tile layer or Distance Matrix queries.
# ---------------------------------------------------------------------------
VITE_MAPS_PROVIDER=osm
VITE_GOOGLE_MAPS_API_KEY=

# ---------------------------------------------------------------------------
# Admin API — Bearer token for the GET /admin endpoint (server-side only)
# Generate a strong random value, e.g.: openssl rand -hex 32
# Leave empty to disable the admin endpoint entirely.
# ---------------------------------------------------------------------------
ADMIN_API_KEY=

# ---------------------------------------------------------------------------
# Feature toggles (set to "true" / "false")
# ---------------------------------------------------------------------------
# Enable experimental two-team seeker mode
VITE_FEATURE_TWO_TEAMS=false
# Enable admin dashboard route
VITE_FEATURE_ADMIN_DASHBOARD=false
# Enable GPS real-time tracking overlay
VITE_FEATURE_GPS_TRACKING=true
