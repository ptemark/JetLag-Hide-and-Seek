# JetLag: The Game — Staging Environment Configuration
#
# Copy this file to .env.staging and fill in real staging values.
# Never commit files with real secrets.
#
# In CI, these variables are injected via GitHub Actions secrets.
# See .github/workflows/ci.yml for how they are wired to each deploy job.

# ---------------------------------------------------------------------------
# Environment name — must be "staging" for this file
# ---------------------------------------------------------------------------
VITE_ENV=staging

# ---------------------------------------------------------------------------
# API — Staging Vercel preview deployment URL
# The Vercel CLI prints the preview URL after a non-prod deploy; record it here.
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=https://jetlag-git-staging.vercel.app

# ---------------------------------------------------------------------------
# WebSocket — Staging managed game-loop container
# Point at the Docker image tagged "staging" deployed via STAGING_MANAGED_SERVER_DEPLOY_WEBHOOK.
# ---------------------------------------------------------------------------
VITE_WS_URL=wss://jetlag-staging-server.example.com

# ---------------------------------------------------------------------------
# Managed game server URL (used by serverless functions to proxy requests)
# ---------------------------------------------------------------------------
GAME_SERVER_URL=https://jetlag-staging-server.example.com

# ---------------------------------------------------------------------------
# Database — Use a separate staging Postgres instance.
# Never share a database between staging and production.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@staging-host:5432/jetlag_staging

# ---------------------------------------------------------------------------
# Maps
# ---------------------------------------------------------------------------
VITE_MAPS_PROVIDER=osm
VITE_GOOGLE_MAPS_API_KEY=

# ---------------------------------------------------------------------------
# Admin API — Use a different key from production
# Generate: openssl rand -hex 32
# ---------------------------------------------------------------------------
ADMIN_API_KEY=

# ---------------------------------------------------------------------------
# Alerting — Optional staging webhook (e.g. a test Slack channel)
# ---------------------------------------------------------------------------
ALERT_WEBHOOK_URL=
ALERT_ERROR_THRESHOLD=10

# ---------------------------------------------------------------------------
# Feature toggles — Enable all experimental features in staging
# ---------------------------------------------------------------------------
VITE_FEATURE_TWO_TEAMS=false
VITE_FEATURE_ADMIN_DASHBOARD=true
VITE_FEATURE_GPS_TRACKING=true
